# Copy to .env.local and customize

# Required — use a long random string (openssl rand -base64 32)
SESSION_SECRET=change-me-to-a-long-random-secret

# Host dashboard at /admin (required for production)
ADMIN_PASSWORD=change-me-to-a-strong-host-password

# Upstash Redis — auto-set when you add the Upstash integration on Vercel.
# For local testing with Redis, copy these from your Upstash dashboard:
# KV_REST_API_URL=
# KV_REST_API_TOKEN=
# (Also accepts UPSTASH_REDIS_REST_URL / UPSTASH_REDIS_REST_TOKEN)

# Guest list for Vercel (optional locally — uses data/guests.json instead)
# Run: node scripts/print-guests-env.mjs
# GUESTS_JSON=

# Event details (optional — defaults are in lib/event.ts)
HOST_NAME=Barbara
EVENT_DATE=Saturday, June 14, 2026
EVENT_TIME=7:00 PM
EVENT_LOCATION=Your venue here
EVENT_DRESS=Smart casual
EVENT_GIFTS=Your presence is enough — gifts are not required
RSVP_DEADLINE=June 1, 2026
